{
	"name": "healthcheck",
	"version": "0.4.5",
	"description": "Simple docker container with healthcheck endpoint API",
	"main": "build/src/index.js",
	"dependencies": {
		"dayjs": "1.11.21",
		"dotenv": "17.4.2",
		"express": "5.2.1",
		"pino": "10.3.1",
		"pino-pretty": "13.1.3"
	},
	"devDependencies": {
		"@eslint/compat": "2.1.0",
		"@eslint/js": "10.0.1",
		"@jest/globals": "^30.3.0",
		"@types/express": "5.0.6",
		"@types/jest": "30.0.0",
		"@types/node": "25.9.5",
		"@types/supertest": "7.2.0",
		"@typescript-eslint/eslint-plugin": "8.63.0",
		"@typescript-eslint/parser": "8.63.0",
		"eslint": "10.6.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-prettier": "5.5.6",
		"globals": "17.7.0",
		"jest": "30.4.2",
		"npm-check-updates": "22.2.9",
		"prettier": "3.9.5",
		"supertest": "7.2.2",
		"ts-jest": "29.4.11",
		"ts-node-dev": "^2.0.0",
		"typescript": "6.0.3",
		"typescript-eslint": "8.63.0"
	},
	"scripts": {
		"start": "node .",
		"build": "tsc --build",
		"dev": "tsnd --respawn ./src/index.ts",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "jest",
		"ncu": "pnpx npm-check-updates",
		"ncu-update": "pnpx npm-check-updates -u"
	},
	"author": "Matus Barta",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/matus-barta/Healthcheck.git"
	},
	"bugs": {
		"url": "https://github.com/matus-barta/Healthcheck/issues"
	},
	"homepage": "https://github.com/matus-barta/Healthcheck#readme"
}
